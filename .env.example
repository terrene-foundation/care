# CARE Assessment Kit — Environment Configuration
# Copy to .env and fill in values

# ─── LLM Provider ───────────────────────────────────────────
# Supported: anthropic, openai, ollama
CARE_LLM_PROVIDER=anthropic
CARE_LLM_MODEL=claude-sonnet-4-6

# API keys (set the one matching your provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# For self-hosted LLM (Ollama, vLLM)
CARE_LLM_BASE_URL=http://localhost:11434

# ─── Server ─────────────────────────────────────────────────
CARE_API_HOST=127.0.0.1
CARE_API_PORT=8000
CARE_CORS_ORIGINS=http://localhost:3000

# ─── Voice (optional) ──────────────────────────────────────
# For self-hosted Whisper transcription
CARE_WHISPER_MODEL=base
CARE_WHISPER_DEVICE=cpu

# ─── Mode ───────────────────────────────────────────────────
# hosted = Foundation-provided LLM (care.terrene.foundation)
# selfhosted = bring your own LLM
CARE_MODE=selfhosted
